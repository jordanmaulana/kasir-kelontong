# --- Django ---
SECRET_KEY=
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://app.example.com

# --- Database ---
# Leave POSTGRES_HOST empty for SQLite (host dev). Compose: POSTGRES_HOST=postgres.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=

# --- Mayar (payments) ---
MAYAR_API_KEY=
MAYAR_WEBHOOK_TOKEN=
MAYAR_BASE_URL=https://api.mayar.id/hl/v1
PAYMENT_REDIRECT_URL=http://localhost:5173/

# --- URLs ---
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Cloudflare Tunnel ---
# Token from CF dashboard (Zero Trust → Networks → Tunnels). Ingress rules
# configured there should map: app.<domain> → http://frontend:80,
# api.<domain> → http://backend:8000.
TUNNEL_TOKEN=

# --- Frontend build args (baked into bundle at docker build time) ---
VITE_API_URL=https://api.example.com
VITE_GOOGLE_CLIENT_ID=
